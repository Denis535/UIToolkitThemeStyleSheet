@import "../Internal/_Theme"

// selector
selector----------tab-view----------normal  = '.unity-tab-view'
// selector
selector----------headers-----------normal  = '.unity-tab-view        .unity-tab-view__header-container'
selector----------header------------normal  = '.unity-tab-view        .unity-tab__header'
selector----------header------------hover   = '.unity-tab-view        .unity-tab__header:hover'
selector----------header------------active  = '.unity-tab-view        .unity-tab__header:active'
selector----------header------------checked = '.unity-tab-view        .unity-tab__header:checked'
selector----------header-icon-------normal  = '.unity-tab-view        .unity-tab__header-image'
selector--empty---header-icon-------normal  = '.unity-tab-view        .unity-tab__header-image--empty'
selector----------header-text-------normal  = '.unity-tab-view        .unity-tab__header-label'
selector----------header-underline--normal  = '.unity-tab-view        .unity-tab__header-underline'
// selector
selector----------tabs--------------normal  = '.unity-tab-view        .unity-tab-view__content-container'
selector----------tabs--------------hover   = '.unity-tab-view        .unity-tab-view__content-container:hover'
selector--light2--tabs--------------normal  = '.unity-tab-view.light2 .unity-tab-view__content-container'
selector--light2--tabs--------------hover   = '.unity-tab-view.light2 .unity-tab-view__content-container:hover'
selector--light---tabs--------------normal  = '.unity-tab-view.light  .unity-tab-view__content-container'
selector--light---tabs--------------hover   = '.unity-tab-view.light  .unity-tab-view__content-container:hover'
selector--gray----tabs--------------normal  = '.unity-tab-view.gray   .unity-tab-view__content-container'
selector--gray----tabs--------------hover   = '.unity-tab-view.gray   .unity-tab-view__content-container:hover'
selector--dark----tabs--------------normal  = '.unity-tab-view.dark   .unity-tab-view__content-container'
selector--dark----tabs--------------hover   = '.unity-tab-view.dark   .unity-tab-view__content-container:hover'
selector--dark2---tabs--------------normal  = '.unity-tab-view.dark2  .unity-tab-view__content-container'
selector--dark2---tabs--------------hover   = '.unity-tab-view.dark2  .unity-tab-view__content-container:hover'
selector--small---tabs--------------normal  = '.unity-tab-view.small  .unity-tab-view__content-container'
selector--medium--tabs--------------normal  = '.unity-tab-view.medium .unity-tab-view__content-container'
selector--large---tabs--------------normal  = '.unity-tab-view.large  .unity-tab-view__content-container'
selector----------tab---------------normal  = '.unity-tab-view        .unity-tab'
selector----------tab---------------checked = '.unity-tab-view        .unity-tab:checked'
selector----------tab-content-------normal  = '.unity-tab-view        .unity-tab__content-container'

// view
add-style(        tab-view----------normal ) theme(                      )
flush()
// view
add-style(        headers-----------normal ) theme(                      )
add-style(        header------------normal ) theme(button--normal        ) font(null, null, bold) text(middle-center, null, null)
add-style(        header------------hover  ) theme(button--hover         )
add-style(        header------------active ) theme(button--active        )
add-style(        header------------checked) theme(button--active        )
add-style(        header-icon-------normal ) theme(                      )
add-style(        header-text-------normal ) theme(                      )
add-style(        header-underline--normal ) theme(                      )
flush()
// view
add-style(        tabs--------------normal ) theme(        scope--normal)
add-style(        tabs--------------hover  ) theme(        scope--hover )
add-style(light2--tabs--------------normal ) theme(light2--scope--normal)
add-style(light2--tabs--------------hover  ) theme(light2--scope--hover )
add-style(light---tabs--------------normal ) theme(light---scope--normal)
add-style(light---tabs--------------hover  ) theme(light---scope--hover )
add-style(gray----tabs--------------normal ) theme(gray----scope--normal)
add-style(gray----tabs--------------hover  ) theme(gray----scope--hover )
add-style(dark----tabs--------------normal ) theme(dark----scope--normal)
add-style(dark----tabs--------------hover  ) theme(dark----scope--hover )
add-style(dark2---tabs--------------normal ) theme(dark2---scope--normal)
add-style(dark2---tabs--------------hover  ) theme(dark2---scope--hover )
add-style(        tab---------------normal ) theme(                     ) property(display, none)
add-style(        tab---------------checked) theme(                     ) property(display, flex)
add-style(        tab-content-------normal ) theme(                     )
flush()

// layout
add-style(        tab-view----------normal) layout(null, auto, auto, (4px            ), (0px), (0px                ))
flush()
// layout
add-style(        headers-----------normal) layout(null, auto, auto, (0px 0px 0px 2px), (0px), (0px                ))
add-style(        header------------normal) layout(null, auto, auto, (0px            ), (1px), (12px 12px 10px 10px))
add-style(        header-icon-------normal) layout(null, auto, auto, (0px            ), (0px), (0px                ))
add-style(        header-text-------normal) layout(null, auto, auto, (0px            ), (0px), (0px                ))
add-style(        header-underline--normal) layout(null, auto, auto, (0px            ), (0px), (0px                ))
flush()
// layout
add-style(        tabs--------------normal) layout(null, auto, auto, (0px            ), (1px), (0px                ))
add-style(small---tabs--------------normal) layout(null, auto, auto, (0px            ), (1px), (6px  6px  5px  5px ))
add-style(medium--tabs--------------normal) layout(null, auto, auto, (0px            ), (1px), (12px 12px 10px 10px))
add-style(large---tabs--------------normal) layout(null, auto, auto, (0px            ), (1px), (24px 24px 20px 20px))
add-style(        tab---------------normal) layout(null, auto, auto, (0px            ), (0px), (0px                ))
add-style(        tab-content-------normal) layout(null, auto, auto, (0px            ), (0px), (0px                ))
flush()

// flex
add-style(        tab-view----------normal) flex(0, 1, auto, auto) flex2(column, flex-start, stretch)
flush()
// flex
add-style(        headers-----------normal) flex(0, 1, auto, auto) flex2(row,    flex-start, stretch)
add-style(        header------------normal) flex(1, 1, auto, auto) flex2(row,    center,     stretch)
add-style(        header-icon-------normal) flex(0, 1, auto, auto)
add-style(        header-text-------normal) flex(0, 1, auto, auto)
add-style(        header-underline--normal) flex(0, 1, auto, auto)
flush()
// flex
add-style(        tabs--------------normal) flex(1, 1, auto, auto) flex2(column, flex-start, stretch)
add-style(        tab---------------normal) flex(1, 1, auto, auto) flex2(column, flex-start, stretch)
add-style(        tab-content-------normal) flex(1, 1, auto, auto) flex2(column, flex-start, stretch)
flush()
