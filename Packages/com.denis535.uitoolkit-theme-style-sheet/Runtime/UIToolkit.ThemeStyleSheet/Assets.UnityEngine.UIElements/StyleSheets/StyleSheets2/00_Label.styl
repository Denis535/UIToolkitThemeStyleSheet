@import "../Internal/_Theme"

// selector
selector--label---------normal = // string: .unity-label
selector--small-label---normal = // string: .unity-label.small
selector--medium-label--normal = // string: .unity-label.medium
selector--large-label---normal = // string: .unity-label.large

// view
.selector--label--normal // styles: add-theme(null).add-font(null, null, null).add-text(upper-left, null, null)

// layout
.selector--label---------normal // styles: add-layout(null, auto, auto, (4px), (1px), (0px  0px  0px  0px ))
.selector--small-label---normal // styles: add-layout(null, auto, auto, (4px), (1px), (6px  6px  5px  5px ))
.selector--medium-label--normal // styles: add-layout(null, auto, auto, (4px), (1px), (12px 12px 10px 10px))
.selector--large-label---normal // styles: add-layout(null, auto, auto, (4px), (1px), (24px 24px 20px 20px))

// flex
.selector--label--normal // styles: add-flex(0, 1, auto, auto)
