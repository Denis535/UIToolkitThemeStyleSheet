@import "../Internal/_Theme"

// selector
selector--group--normal         = // string: .group
selector--group--hover          = // string: .group:hover
selector--group--light2--normal = // string: .group.light2
selector--group--light2--hover  = // string: .group.light2:hover
selector--group--light---normal = // string: .group.light
selector--group--light---hover  = // string: .group.light:hover
selector--group--gray----normal = // string: .group.gray
selector--group--gray----hover  = // string: .group.gray:hover
selector--group--dark----normal = // string: .group.dark
selector--group--dark----hover  = // string: .group.dark:hover
selector--group--dark2---normal = // string: .group.dark2
selector--group--dark2---hover  = // string: .group.dark2:hover
selector--group--small          = // string: .group.small
selector--group--medium         = // string: .group.medium
selector--group--large          = // string: .group.large
selector--group--column         = // string: .column-group
selector--group--row            = // string: .row-group

// view
.selector--group--normal         // styles: add-theme(scope---------normal)
.selector--group--hover          // styles: add-theme(scope---------hover )
.selector--group--light2--normal // styles: add-theme(light2-scope--normal)
.selector--group--light2--hover  // styles: add-theme(light2-scope--hover )
.selector--group--light---normal // styles: add-theme(light-scope---normal)
.selector--group--light---hover  // styles: add-theme(light-scope---hover )
.selector--group--gray----normal // styles: add-theme(gray-scope----normal)
.selector--group--gray----hover  // styles: add-theme(gray-scope----hover )
.selector--group--dark----normal // styles: add-theme(dark-scope----normal)
.selector--group--dark----hover  // styles: add-theme(dark-scope----hover )
.selector--group--dark2---normal // styles: add-theme(dark2-scope---normal)
.selector--group--dark2---hover  // styles: add-theme(dark2-scope---hover )

// layout
.selector--group--normal // styles: add-layout(null, auto, auto, (4px), (1px), (0px                ))
.selector--group--small  // styles: add-layout(null, auto, auto, (4px), (1px), (6px  6px  5px  5px ))
.selector--group--medium // styles: add-layout(null, auto, auto, (4px), (1px), (12px 12px 10px 10px))
.selector--group--large  // styles: add-layout(null, auto, auto, (4px), (1px), (24px 24px 20px 20px))

// flex
.selector--group--column // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
.selector--group--row    // styles: add-flex(0, 1, auto, auto).add-flex2(row,    flex-start, null, stretch)
