@import "../Internal/_Theme"

// selector
selector--group         = // string: .group:*
selector--group--light2 = // string: .group.light2:*
selector--group--light  = // string: .group.light:*
selector--group--gray   = // string: .group.gray:*
selector--group--dark   = // string: .group.dark:*
selector--group--dark2  = // string: .group.dark2:*
selector--group--small  = // string: .group.small
selector--group--medium = // string: .group.medium
selector--group--large  = // string: .group.large
selector--group--column = // string: .group.column
selector--group--row    = // string: .group.row

// view
.selector--group               // styles: add-theme(scope--normal        )
.selector--group--light2       // styles: add-theme(scope--light2--normal)
.selector--group--light        // styles: add-theme(scope--light---normal)
.selector--group--gray         // styles: add-theme(scope--gray----normal)
.selector--group--dark         // styles: add-theme(scope--dark----normal)
.selector--group--dark2        // styles: add-theme(scope--dark2---normal)

// view/hover
.selector--group:hover         // styles: add-theme(scope--hover         )
.selector--group--light2:hover // styles: add-theme(scope--light2--hover )
.selector--group--light:hover  // styles: add-theme(scope--light---hover )
.selector--group--gray:hover   // styles: add-theme(scope--gray----hover )
.selector--group--dark:hover   // styles: add-theme(scope--dark----hover )
.selector--group--dark2:hover  // styles: add-theme(scope--dark2---hover )

// layout
.selector--group         // styles: add-layout(null, auto, auto, (4px), (1px), (0px                ))
.selector--group--small  // styles: add-layout(null, auto, auto, (4px), (1px), (6px  6px  5px  5px ))
.selector--group--medium // styles: add-layout(null, auto, auto, (4px), (1px), (12px 12px 10px 10px))
.selector--group--large  // styles: add-layout(null, auto, auto, (4px), (1px), (24px 24px 20px 20px))

// flex
.selector--group--column // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
.selector--group--row    // styles: add-flex(0, 1, auto, auto).add-flex2(row,    flex-start, null, stretch)
