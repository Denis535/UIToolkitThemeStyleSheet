@import "../Internal/_Theme"

// selector
selector--tab-view                  = // string: .unity-tab-view
selector--tab-view-headers          = // string: .unity-tab-view .unity-tab-view__header-container
selector--tab-view-contents         = // string: .unity-tab-view .unity-tab-view__content-container
// selector
selector--tab-view-header           = // string: .unity-tab-view .unity-tab__header:*
selector--tab-view-header-icon      = // string: .unity-tab-view .unity-tab__header:* .unity-tab__header-image
selector--tab-view-header-text      = // string: .unity-tab-view .unity-tab__header:* .unity-tab__header-label
selector--tab-view-header-underline = // string: .unity-tab-view .unity-tab__header:* .unity-tab__header-underline
// selector
selector--tab-view-content          = // string: .unity-tab-view        .unity-tab:*
selector--tab-view-content--light2  = // string: .unity-tab-view.light2 .unity-tab:*
selector--tab-view-content--light   = // string: .unity-tab-view.light  .unity-tab:*
selector--tab-view-content--gray    = // string: .unity-tab-view.gray   .unity-tab:*
selector--tab-view-content--dark    = // string: .unity-tab-view.dark   .unity-tab:*
selector--tab-view-content--dark2   = // string: .unity-tab-view.dark2  .unity-tab:*
selector--tab-view-content--small   = // string: .unity-tab-view.small  .unity-tab:*
selector--tab-view-content--medium  = // string: .unity-tab-view.medium .unity-tab:*
selector--tab-view-content--large   = // string: .unity-tab-view.large  .unity-tab:*
selector--tab-view-container        = // string: .unity-tab-view        .unity-tab .unity-tab__content-container

// view
.selector--tab-view-header                   // styles: add-theme(button--normal                    ).add-font(null, null, null).add-text(middle-center, null, null)
.selector--tab-view-header-icon              // styles: add-theme(null                              )
.selector--tab-view-header-text              // styles: add-theme(null                              )
.selector--tab-view-header-underline         // styles: add-theme(tab-view-header-underline--normal )
// view
.selector--tab-view-content                  // styles: add-theme(scope--normal                     ).add-property(display, none)
.selector--tab-view-content--light2          // styles: add-theme(scope--light2--normal             )
.selector--tab-view-content--light           // styles: add-theme(scope--light---normal             )
.selector--tab-view-content--gray            // styles: add-theme(scope--gray----normal             )
.selector--tab-view-content--dark            // styles: add-theme(scope--dark----normal             )
.selector--tab-view-content--dark2           // styles: add-theme(scope--dark2---normal             )

// view/hover
.selector--tab-view-header:hover             // styles: add-theme(button--hover                     )
.selector--tab-view-header-icon:hover        // styles: add-theme(null                              )
.selector--tab-view-header-text:hover        // styles: add-theme(null                              )
.selector--tab-view-header-underline:hover   // styles: add-theme(tab-view-header-underline--hover  )
// view/hover
.selector--tab-view-content:hover            // styles: add-theme(scope--hover                      )
.selector--tab-view-content--light2:hover    // styles: add-theme(scope--light2--hover              )
.selector--tab-view-content--light:hover     // styles: add-theme(scope--light---hover              )
.selector--tab-view-content--gray:hover      // styles: add-theme(scope--gray----hover              )
.selector--tab-view-content--dark:hover      // styles: add-theme(scope--dark----hover              )
.selector--tab-view-content--dark2:hover     // styles: add-theme(scope--dark2---hover              )

// view/checked
.selector--tab-view-header:checked           // styles: add-theme(null                              )
.selector--tab-view-header-icon:checked      // styles: add-theme(null                              )
.selector--tab-view-header-text:checked      // styles: add-theme(null                              )
.selector--tab-view-header-underline:checked // styles: add-theme(tab-view-header-underline--checked)
// view/checked
.selector--tab-view-content:checked          // styles: add-theme(null                              ).add-property(display, flex)

// layout
.selector--tab-view                  // styles: add-layout(null,                         auto, auto, (4px            ), (0px), (0px                ))
.selector--tab-view-headers          // styles: add-layout(null,                         auto, auto, (0px            ), (0px), (0px                ))
.selector--tab-view-contents         // styles: add-layout(null,                         auto, auto, (0px 0px 6px 0px), (0px), (0px                ))
// layout
.selector--tab-view-header           // styles: add-layout(null,                         auto, auto, (0px            ), (1px), (12px 12px 10px 10px))
.selector--tab-view-header-icon      // styles: add-layout(null,                         auto, auto, (0px            ), (0px), (0px                ))
.selector--tab-view-header-text      // styles: add-layout(null,                         auto, auto, (0px            ), (0px), (0px                ))
.selector--tab-view-header-underline // styles: add-layout(absolute null null null -2px, 100%, 6px,  (0px            ), (1px), (0px                ))
// layout
.selector--tab-view-content          // styles: add-layout(null,                         auto, auto, (0px            ), (1px), (0px                ))
.selector--tab-view-content--small   // styles: add-layout(null,                         auto, auto, (0px            ), (1px), (6px  6px  5px  5px ))
.selector--tab-view-content--medium  // styles: add-layout(null,                         auto, auto, (0px            ), (1px), (12px 12px 10px 10px))
.selector--tab-view-content--large   // styles: add-layout(null,                         auto, auto, (0px            ), (1px), (24px 24px 20px 20px))
.selector--tab-view-container        // styles: add-layout(null,                         auto, auto, (0px            ), (0px), (0px                ))

// flex
.selector--tab-view                  // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
.selector--tab-view-headers          // styles: add-flex(0, 1, auto, auto).add-flex2(row,    flex-start, null, stretch)
.selector--tab-view-contents         // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
// flex
.selector--tab-view-header           // styles: add-flex(1, 1, auto, auto).add-flex2(row,    center,     null, stretch)
.selector--tab-view-header-icon      // styles: add-flex(0, 1, auto, auto)
.selector--tab-view-header-text      // styles: add-flex(0, 1, auto, auto)
.selector--tab-view-header-underline // styles: add-flex(0, 1, auto, auto)
// flex
.selector--tab-view-content          // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
.selector--tab-view-container        // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
