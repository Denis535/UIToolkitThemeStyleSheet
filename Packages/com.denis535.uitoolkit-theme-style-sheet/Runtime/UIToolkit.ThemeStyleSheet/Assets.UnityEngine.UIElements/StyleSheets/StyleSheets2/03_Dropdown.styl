@import "../Internal/_Theme"

// selector
selector--dropdown------------------------normal  = // string: .unity-base-dropdown
// selector
selector--scroll-view---------------------normal  = // string: .unity-base-dropdown .unity-scroll-view
selector--scroll-view---------------------hover   = // string: .unity-base-dropdown .unity-scroll-view:hover
selector--viewport-and-vertical-scroller--normal  = // string: .unity-base-dropdown .unity-scroll-view #unity-content-and-vertical-scroll-container
selector--viewport------------------------normal  = // string: .unity-base-dropdown .unity-scroll-view #unity-content-viewport
selector--content-------------------------normal  = // string: .unity-base-dropdown .unity-scroll-view #unity-content-container
// selector
selector--dropdown-item-------------------normal  = // string: .unity-base-dropdown .unity-base-dropdown__item
selector--dropdown-item-------------------hover   = // string: .unity-base-dropdown .unity-base-dropdown__item:hover
selector--dropdown-item-------------------checked = // string: .unity-base-dropdown .unity-base-dropdown__item:checked
selector--checkmark-----------------------normal  = // string: .unity-base-dropdown .unity-base-dropdown__item         .unity-base-dropdown__checkmark
selector--checkmark-----------------------hover   = // string: .unity-base-dropdown .unity-base-dropdown__item:hover   .unity-base-dropdown__checkmark
selector--checkmark-----------------------checked = // string: .unity-base-dropdown .unity-base-dropdown__item:checked .unity-base-dropdown__checkmark
selector--text----------------------------normal  = // string: .unity-base-dropdown .unity-base-dropdown__item         .unity-base-dropdown__label
selector--text----------------------------hover   = // string: .unity-base-dropdown .unity-base-dropdown__item:hover   .unity-base-dropdown__label
selector--text----------------------------checked = // string: .unity-base-dropdown .unity-base-dropdown__item:checked .unity-base-dropdown__label

// view
.selector--dropdown------------------------normal  // styles: add-theme(null                            )
// view
.selector--scroll-view---------------------normal  // styles: add-theme(dropdown-----------------normal )
.selector--scroll-view---------------------hover   // styles: add-theme(dropdown-----------------hover  )
.selector--viewport-and-vertical-scroller--normal  // styles: add-theme(null                            )
.selector--viewport------------------------normal  // styles: add-theme(null                            )
.selector--content-------------------------normal  // styles: add-theme(null                            )
// view
.selector--dropdown-item-------------------normal  // styles: add-theme(dropdown-item------------normal )
.selector--dropdown-item-------------------hover   // styles: add-theme(dropdown-item------------hover  )
.selector--dropdown-item-------------------checked // styles: add-theme(null                            )
.selector--checkmark-----------------------normal  // styles: add-theme(dropdown-item-checkmark--normal )
.selector--checkmark-----------------------hover   // styles: add-theme(dropdown-item-checkmark--hover  )
.selector--checkmark-----------------------checked // styles: add-theme(dropdown-item-checkmark--checked)
.selector--text----------------------------normal  // styles: add-theme(null                            )
.selector--text----------------------------hover   // styles: add-theme(null                            )
.selector--text----------------------------checked // styles: add-theme(null                            )

// layout
.selector--dropdown------------------------normal // styles: add-layout(absolute, auto, auto, (0px             ), (0px            ), (0px                ))
// layout
.selector--scroll-view---------------------normal // styles: add-layout(null,     auto, auto, (0px             ), (1px            ), (0px                ))
.selector--viewport-and-vertical-scroller--normal // styles: add-layout(null,     auto, auto, (0px             ), (0px            ), (0px                ))
.selector--viewport------------------------normal // styles: add-layout(null,     auto, auto, (0px             ), (0px            ), (0px                ))
.selector--content-------------------------normal // styles: add-layout(null,     auto, auto, (0px             ), (0px            ), (0px                ))
// layout
.selector--dropdown-item-------------------normal // styles: add-layout(null,     auto, auto, (0px             ), (0px 0px 0px 1px), (12px 12px 10px 10px))
.selector--checkmark-----------------------normal // styles: add-layout(null,     16px, 16px, (0px 12px 0px 0px), (1px            ), (0px                ))
.selector--text----------------------------normal // styles: add-layout(null,     auto, auto, (0px             ), (0px            ), (0px                ))

// flex
.selector--dropdown------------------------normal // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, stretch)
// flex
.selector--scroll-view---------------------normal // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, stretch)
.selector--viewport-and-vertical-scroller--normal // styles: add-flex(1, 1, auto, auto).add-flex2(row,    flex-start, stretch)
.selector--viewport------------------------normal // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, stretch)
.selector--content-------------------------normal // styles: add-flex(0, 0, auto, auto).add-flex2(column, flex-start, stretch)
// flex
.selector--dropdown-item-------------------normal // styles: add-flex(0, 1, auto, auto).add-flex2(row,    flex-start, stretch)
.selector--checkmark-----------------------normal // styles: add-flex(0, 1, auto, auto)
.selector--text----------------------------normal // styles: add-flex(1, 1, auto, auto)
