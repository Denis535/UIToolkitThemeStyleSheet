@import "../Internal/_Theme"

// selector
selector--scroller              = // string: .unity-scroller--vertical
selector--field                 = // string: .unity-scroller--vertical .unity-base-slider
selector--field-input           = // string: .unity-scroller--vertical .unity-base-slider   .unity-base-slider__input
selector--field-input-container = // string: .unity-scroller--vertical .unity-base-slider   .unity-base-slider__input #unity-drag-container
selector--field-input-tracker   = // string: .unity-scroller--vertical .unity-base-slider.% .unity-base-slider__input #unity-drag-container #unity-tracker
selector--field-input-dragger   = // string: .unity-scroller--vertical .unity-base-slider.% .unity-base-slider__input #unity-drag-container #unity-dragger
selector--low-button            = // string: .unity-scroller--vertical #unity-low-button.%
selector--high-button           = // string: .unity-scroller--vertical #unity-high-button.%

// view
.selector--scroller                         // styles: add-theme(null                                        )
.selector--field                            // styles: add-theme(null                                        )
.selector--field-input                      // styles: add-theme(null                                        )
.selector--field-input-container            // styles: add-theme(null                                        )
.selector--field-input-tracker              // styles: add-theme(scroll-view-tracker------------normal       )
.selector--field-input-dragger              // styles: add-theme(scroll-view-dragger------------normal       )
.selector--low-button                       // styles: add-theme(scroll-view-up-arrow-button----normal       )
.selector--high-button                      // styles: add-theme(scroll-view-down-arrow-button--normal       )

// view/hover
.selector--field-input-tracker:hover        // styles: add-theme(scroll-view-tracker------------hover        )
.selector--field-input-dragger:hover        // styles: add-theme(scroll-view-dragger------------hover        )
.selector--low-button:hover                 // styles: add-theme(scroll-view-up-arrow-button----hover        )
.selector--high-button:hover                // styles: add-theme(scroll-view-down-arrow-button--hover        )

// view/active
.selector--field-input-tracker:active       // styles: add-theme(scroll-view-tracker------------active       )
.selector--field-input-dragger:active       // styles: add-theme(scroll-view-dragger------------active       )
.selector--low-button:active                // styles: add-theme(scroll-view-up-arrow-button----active       )
.selector--high-button:active               // styles: add-theme(scroll-view-down-arrow-button--active       )

// view/focus
.selector--field-input-dragger:focus        // styles: add-theme(scroll-view-dragger------------focus        )
.selector--low-button:focus                 // styles: add-theme(scroll-view-up-arrow-button----focus        )
.selector--high-button:focus                // styles: add-theme(scroll-view-down-arrow-button--focus        )

// view/focus/hover
.selector--field-input-dragger:focus:hover  // styles: add-theme(scroll-view-dragger------------focus--hover )
.selector--low-button:focus:hover           // styles: add-theme(scroll-view-up-arrow-button----focus--hover )
.selector--high-button:focus:hover          // styles: add-theme(scroll-view-down-arrow-button--focus--hover )

// view/focus/active
.selector--field-input-dragger:focus:active // styles: add-theme(scroll-view-dragger------------focus--active)
.selector--low-button:focus:active          // styles: add-theme(scroll-view-up-arrow-button----focus--active)
.selector--high-button:focus:active         // styles: add-theme(scroll-view-down-arrow-button--focus--active)

// layout
.selector--scroller              // styles: add-layout(null,     auto, auto, (0px 2px 2px 2px), (0px), (0px))
.selector--field                 // styles: add-layout(null,     auto, auto, (0px 0px 2px 2px), (0px), (0px))
.selector--field-input           // styles: add-layout(null,     auto, auto, (0px            ), (0px), (0px))
.selector--field-input-container // styles: add-layout(null,     auto, auto, (0px            ), (0px), (0px))
.selector--field-input-tracker   // styles: add-layout(null,     24px, auto, (0px            ), (1px), (0px))
.selector--field-input-dragger   // styles: add-layout(absolute, 24px, auto, (0px            ), (1px), (0px))
.selector--low-button            // styles: add-layout(null,     24px, 24px, (0px            ), (1px), (0px))
.selector--high-button           // styles: add-layout(null,     24px, 24px, (0px            ), (1px), (0px))

// flex
.selector--scroller              // styles: add-flex(0, 0, auto, auto).add-flex2(column, flex-start, null, center)
.selector--field                 // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, null, center)
.selector--field-input           // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, null, center)
.selector--field-input-container // styles: add-flex(1, 1, auto, auto).add-flex2(column, flex-start, null, center)
.selector--field-input-tracker   // styles: add-flex(1, 1, auto, auto)
.selector--field-input-dragger   // styles: add-flex(0, 1, auto, auto)
.selector--low-button            // styles: add-flex(0, 0, auto, auto)
.selector--high-button           // styles: add-flex(0, 0, auto, auto)
