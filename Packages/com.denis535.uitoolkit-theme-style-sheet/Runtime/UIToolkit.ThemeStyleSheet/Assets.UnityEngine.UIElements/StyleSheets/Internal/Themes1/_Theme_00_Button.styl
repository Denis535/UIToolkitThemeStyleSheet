@import "../_Utils"

// button
theme--button--normal                  = hsla(  0,   0%,  90%, 1.00) bg(hsla(210,  2%, 23%, 1.00) img(null, null)) bd(hsla( 30,  30%, 30%, 1.00) 4px )
theme--button--hover                   = hsla(  0,   0%, 100%, 1.00) bg(hsla(210,  2%, 25%, 1.00) null           ) bd(hsla( 30,  30%, 50%, 1.00) null)
theme--button--active                  = hsla(  0,   0%,  50%, 1.00) bg(hsla(210,  2%, 22%, 1.00) null           ) bd(hsla( 30,  30%, 20%, 1.00) null)
// button
theme--button--focus                   = hsla(210,  80%,  50%, 1.00) bg(null                      null           ) bd(hsla(210,  80%, 40%, 1.00) null)
theme--button--focus--hover            = hsla(210, 100%,  60%, 1.00) bg(null                      null           ) bd(hsla(210,  80%, 50%, 1.00) null)
theme--button--focus--active           = hsla(210,  80%,  40%, 1.00) bg(null                      null           ) bd(hsla(210,  80%, 20%, 1.00) null)
// button
theme--button--invalid                 = hsla(  0,  80%,  50%, 1.00) bg(null                      null           ) bd(hsla(  0,  80%, 40%, 1.00) null)
theme--button--invalid--hover          = hsla(  0, 100%,  60%, 1.00) bg(null                      null           ) bd(hsla(  0,  80%, 50%, 1.00) null)
theme--button--invalid--active         = hsla(  0,  80%,  40%, 1.00) bg(null                      null           ) bd(hsla(  0,  80%, 20%, 1.00) null)
// button
theme--button--invalid--focus          = hsla(  0,  80%,  50%, 1.00) bg(null                      null           ) bd(hsla(210,  80%, 40%, 1.00) null)
theme--button--invalid--focus--hover   = hsla(  0, 100%,  60%, 1.00) bg(null                      null           ) bd(hsla(210,  80%, 50%, 1.00) null)
theme--button--invalid--focus--active  = hsla(  0,  80%,  40%, 1.00) bg(null                      null           ) bd(hsla(210,  80%, 20%, 1.00) null)
