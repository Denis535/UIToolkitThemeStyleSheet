@import "../_Utils"

// button
theme--button--normal                  = create-theme(hsla(  0,   0%,  90%, 1.00) hsla(210,  2%, 23%, 1.00) img(null, null, null) hsla( 30,  30%, 30%, 1.00) 4px )
theme--button--hover                   = create-theme(hsla(  0,   0%, 100%, 1.00) hsla(210,  2%, 25%, 1.00) null                  hsla( 30,  30%, 50%, 1.00) null)
theme--button--active                  = create-theme(hsla(  0,   0%,  50%, 1.00) hsla(210,  2%, 22%, 1.00) null                  hsla( 30,  30%, 20%, 1.00) null)
// button
theme--button--focus                   = create-theme(hsla(210,  80%,  50%, 1.00) null                      null                  hsla(210,  80%, 40%, 1.00) null)
theme--button--focus--hover            = create-theme(hsla(210, 100%,  60%, 1.00) null                      null                  hsla(210,  80%, 50%, 1.00) null)
theme--button--focus--active           = create-theme(hsla(210,  80%,  40%, 1.00) null                      null                  hsla(210,  80%, 20%, 1.00) null)
// button
theme--button--invalid                 = create-theme(hsla(  0,  80%,  50%, 1.00) null                      null                  hsla(  0,  80%, 40%, 1.00) null)
theme--button--invalid--hover          = create-theme(hsla(  0, 100%,  60%, 1.00) null                      null                  hsla(  0,  80%, 50%, 1.00) null)
theme--button--invalid--active         = create-theme(hsla(  0,  80%,  40%, 1.00) null                      null                  hsla(  0,  80%, 20%, 1.00) null)
// button
theme--button--invalid--focus          = create-theme(hsla(  0,  80%,  50%, 1.00) null                      null                  hsla(210,  80%, 40%, 1.00) null)
theme--button--invalid--focus--hover   = create-theme(hsla(  0, 100%,  60%, 1.00) null                      null                  hsla(210,  80%, 50%, 1.00) null)
theme--button--invalid--focus--active  = create-theme(hsla(  0,  80%,  40%, 1.00) null                      null                  hsla(210,  80%, 20%, 1.00) null)
