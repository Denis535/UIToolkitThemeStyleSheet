@import "../_Utils"

// dropdown
theme--dropdown-----------------normal        = create-theme(null                        hsla(210,  2%, 15%, 0.97) img(null, null, null) hsla( 30, 30%, 30%, 1.00) 4px )
theme--dropdown-----------------hover         = create-theme(null                        null                      null                  hsla( 30, 30%, 50%, 1.00) null)
theme--dropdown-----------------active        = create-theme(null                        null                      null                  null                      null)
// dropdown
theme--dropdown-----------------focus         = create-theme(null                        null                      null                  hsla(210, 80%, 40%, 1.00) null)
theme--dropdown-----------------focus--hover  = create-theme(null                        null                      null                  hsla(210, 80%, 50%, 1.00) null)
theme--dropdown-----------------focus--active = create-theme(null                        null                      null                  null                      null)

// dropdown-item
theme--dropdown-item------------normal        = create-theme(hsla(  0,   0%,  90%, 1.00) hsla(  0,  0%, 0%,  0.00) img(null, null, null) hsla(  0,  0%, 0%,  0.00) 0px )
theme--dropdown-item------------hover         = create-theme(hsla(  0,   0%, 100%, 1.00) hsla( 30, 80%, 40%, 1.00) null                  hsla( 30, 80%, 50%, 1.00) null)
theme--dropdown-item------------active        = create-theme(null                        null                      null                  null                      null)
// dropdown-item
theme--dropdown-item------------focus         = create-theme(null                        null                      null                  null                      null)
theme--dropdown-item------------focus--hover  = create-theme(null                        null                      null                  null                      null)
theme--dropdown-item------------focus--active = create-theme(null                        null                      null                  null                      null)

// dropdown-item-checkmark
theme--dropdown-item-checkmark--normal        = create-theme(null                        hsla(  0, 0%,  0%, 0.00)  img('../../Images/Check.png', hsla(  0,  0%,   0%, 0.00), null)  hsla( 0,  0%,  0%, 0.00)  2px )
theme--dropdown-item-checkmark--hover         = create-theme(null                        null                      img(null,                     null,                       null)  null                      null)
theme--dropdown-item-checkmark--active        = create-theme(null                        null                      img(null,                     null,                       null)  null                      null)
theme--dropdown-item-checkmark--checked       = create-theme(null                        null                      img(null,                     hsla(  0,  0%,  90%, 1.00), null)  null                      null)
