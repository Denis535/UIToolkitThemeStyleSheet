@import "../_Utils"

checkmark = '../../Images/Check.png'

// dropdown
theme--dropdown-----------------normal        = null                        bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla( 30, 30%, 30%, 1.00) 4px )
theme--dropdown-----------------hover         = null                        bg(null                      null                                      ) bd(hsla( 30, 30%, 50%, 1.00) null)
theme--dropdown-----------------active        = null                        bg(null                      null                                      ) bd(null                      null)
// dropdown
theme--dropdown-----------------focus         = null                        bg(null                      null                                      ) bd(hsla(210, 80%, 40%, 1.00) null)
theme--dropdown-----------------focus--hover  = null                        bg(null                      null                                      ) bd(hsla(210, 80%, 50%, 1.00) null)
theme--dropdown-----------------focus--active = null                        bg(null                      null                                      ) bd(null                      null)

// dropdown-item
theme--dropdown-item------------normal        = hsla(  0,   0%,  90%, 1.00) bg(hsla(  0,  0%, 0%,  0.00) img(null, null)                           ) bd(hsla(  0,  0%, 0%,  0.00) 0px )
theme--dropdown-item------------hover         = hsla(  0,   0%, 100%, 1.00) bg(hsla( 30, 80%, 40%, 1.00) null                                      ) bd(hsla( 30, 80%, 50%, 1.00) null)
theme--dropdown-item------------active        = null                        bg(null                      null                                      ) bd(null                      null)
// dropdown-item
theme--dropdown-item------------focus         = null                        bg(null                      null                                      ) bd(null                      null)
theme--dropdown-item------------focus--hover  = null                        bg(null                      null                                      ) bd(null                      null)
theme--dropdown-item------------focus--active = null                        bg(null                      null                                      ) bd(null                      null)

// dropdown-item-checkmark
theme--dropdown-item-checkmark--normal        = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(checkmark, hsla(  0,  0%,   0%, 0.00))) bd(hsla( 0,  0%,  0%, 0.00)  2px )
theme--dropdown-item-checkmark--hover         = null                        bg(null                      img(null,      null,                     )) bd(null                      null)
theme--dropdown-item-checkmark--active        = null                        bg(null                      img(null,      null,                     )) bd(null                      null)
theme--dropdown-item-checkmark--checked       = null                        bg(null                      img(null,      hsla(  0,  0%,  90%, 1.00))) bd(null                      null)
