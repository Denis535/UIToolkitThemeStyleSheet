@import "../_Utils"

// tab-view-header
theme--tab-view-header------------normal  = hsla(  0,   0%,  90%, 1.00) bg(hsla( 30,  2%, 23%, 1.00) img(null, null)) bd(hsla( 30, 30%, 30%, 1.00) 4px)
theme--tab-view-header------------hover   = hsla(  0,   0%, 100%, 1.00) bg(hsla( 30,  2%, 25%, 1.00) img(null, null)) bd(hsla( 30, 30%, 50%, 1.00) 4px)
theme--tab-view-header------------active  = hsla(  0,   0%,  50%, 1.00) bg(hsla( 30,  2%, 22%, 1.00) img(null, null)) bd(hsla( 30, 30%, 20%, 1.00) 4px)
theme--tab-view-header------------checked = null                        bg(null                      img(null, null)) bd(hsla( 30, 30%, 50%, 1.00) 4px)

// tab-view-header-underline
theme--tab-view-header-underline--normal  = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(null, null)) bd(hsla(  0,  0%,  0%, 0.00) 4px)
theme--tab-view-header-underline--hover   = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(null, null)) bd(hsla(  0,  0%,  0%, 0.00) 4px)
theme--tab-view-header-underline--active  = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(null, null)) bd(hsla(  0,  0%,  0%, 0.00) 4px)
theme--tab-view-header-underline--checked = null                        bg(hsla( 30, 2%, 50%, 1.00)  img(null, null)) bd(hsla(  0,  0%,  0%, 0.00) 4px)
