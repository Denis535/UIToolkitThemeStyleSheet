@import "../_Utils"

// tab-view-header
theme--tab-view-header------------normal  = create-theme(hsla(  0,   0%,  90%, 1.00) hsla(210,  2%, 23%, 1.00) img(null, null, null) hsla( 30,  30%, 30%, 1.00) 4px )
theme--tab-view-header------------hover   = create-theme(hsla(  0,   0%, 100%, 1.00) hsla(210,  2%, 25%, 1.00) null                  hsla( 30,  30%, 50%, 1.00) null)
theme--tab-view-header------------active  = create-theme(hsla(  0,   0%,  50%, 1.00) hsla(210,  2%, 22%, 1.00) null                  hsla( 30,  30%, 20%, 1.00) null)
theme--tab-view-header------------checked = create-theme(null                        null                      null                  null                       null)

// tab-view-header-underline
theme--tab-view-header-underline--normal  = create-theme(null                        hsla(  0, 0%,  0%, 0.00)  img(null, null, null) hsla( 0,  0%,  0%, 0.00)  (0px 0px 4px 4px))
theme--tab-view-header-underline--hover   = create-theme(null                        null                      img(null, null, null) null                      null             )
theme--tab-view-header-underline--active  = create-theme(null                        null                      img(null, null, null) null                      null             )
theme--tab-view-header-underline--checked = create-theme(null                        hsla(210, 2%, 50%, 1.00)  img(null, null, null) hsla(30, 30%, 30%, 0.50)  null             )
