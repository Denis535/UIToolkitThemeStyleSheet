@import "../_Utils"

// scroll-view-tracker
theme--scroll-view-tracker--normal                   = hsla(  0,   0%,  90%, 1.00) bg(hsla(210,  2%, 17%, 1.00) img(null, null)                                                 ) bd(hsla( 30,  30%, 30%, 1.00) 4px )
theme--scroll-view-tracker--hover                    = null                        bg(null                      null                                                            ) bd(null                       null)
theme--scroll-view-tracker--active                   = null                        bg(null                      null                                                            ) bd(null                       null)

