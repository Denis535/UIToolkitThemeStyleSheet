@import "../_Utils"

checkmark = '../../Images/Check.png'

// dropdown
theme--dropdown-----------------normal        = hsla(  0,   0%,  90%, 1.00) bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla( 30, 30%, 30%, 1.00) 4px)
theme--dropdown-----------------hover         = hsla(  0,   0%, 100%, 1.00) bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla( 30, 30%, 50%, 1.00) 4px)
theme--dropdown-----------------active        = hsla(  0,   0%,  90%, 1.00) bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla( 30, 30%, 30%, 1.00) 4px)
// dropdown
theme--dropdown-----------------focus         = hsla(  0,   0%,  90%, 1.00) bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla(210, 80%, 40%, 1.00) 4px)
theme--dropdown-----------------focus--hover  = hsla(  0,   0%, 100%, 1.00) bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla(210, 80%, 50%, 1.00) 4px)
theme--dropdown-----------------focus--active = hsla(  0,   0%,  90%, 1.00) bg(hsla(210,  2%, 15%, 0.97) img(null, null)                           ) bd(hsla(210, 80%, 40%, 1.00) 4px)

// dropdown-item
theme--dropdown-item------------normal        = hsla(  0,   0%,  90%, 1.00) bg(hsla(  0,  0%, 0%,  0.00) img(null, null)                           ) bd(hsla(  0,  0%, 0%,  0.00) 0px)
theme--dropdown-item------------hover         = hsla(  0,   0%, 100%, 1.00) bg(hsla( 30, 80%, 40%, 1.00) img(null, null)                           ) bd(hsla( 30, 80%, 50%, 1.00) 0px)
theme--dropdown-item------------active        = hsla(  0,   0%,  90%, 1.00) bg(hsla( 30, 80%, 40%, 1.00) img(null, null)                           ) bd(hsla( 30, 80%, 50%, 1.00) 0px)
// dropdown-item
theme--dropdown-item------------focus         = hsla(  0,   0%,  90%, 1.00) bg(hsla(  0,  0%, 0%,  0.00) img(null, null)                           ) bd(hsla(  0,  0%, 0%,  0.00) 0px)
theme--dropdown-item------------focus--hover  = hsla(  0,   0%, 100%, 1.00) bg(hsla( 30, 80%, 40%, 1.00) img(null, null)                           ) bd(hsla( 30, 80%, 50%, 1.00) 0px)
theme--dropdown-item------------focus--active = hsla(  0,   0%,  90%, 1.00) bg(hsla( 30, 80%, 40%, 1.00) img(null, null)                           ) bd(hsla( 30, 80%, 50%, 1.00) 0px)

// dropdown-item-checkmark
theme--dropdown-item-checkmark--normal        = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(checkmark, hsla(  0,  0%,   0%, 0.00))) bd(hsla(  0,  0%,  0%, 0.00) 2px)
theme--dropdown-item-checkmark--hover         = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(checkmark, hsla(  0,  0%,   0%, 0.00))) bd(hsla(  0,  0%,  0%, 0.00) 2px)
theme--dropdown-item-checkmark--active        = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(checkmark, hsla(  0,  0%,   0%, 0.00))) bd(hsla(  0,  0%,  0%, 0.00) 2px)
theme--dropdown-item-checkmark--checked       = null                        bg(hsla(  0, 0%,  0%, 0.00)  img(checkmark, hsla(  0,  0%,  90%, 1.00))) bd(hsla(  0,  0%,  0%, 0.00) 2px)
