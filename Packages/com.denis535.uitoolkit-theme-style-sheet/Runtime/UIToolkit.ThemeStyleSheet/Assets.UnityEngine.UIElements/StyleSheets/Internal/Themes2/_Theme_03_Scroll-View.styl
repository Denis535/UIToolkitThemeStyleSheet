theme--scroll-view-left-arrow-button---hover         = null                        bg(hsla( 30,  2%, 25%, 1.00) img(left-arrow,  hsla(  0,   0%, 100%, 1.00))) bd(hsla( 30,  30%, 50%, 1.00) 4px)
theme--scroll-view-left-arrow-button---active        = null                        bg(hsla( 30,  2%, 22%, 1.00) img(left-arrow,  hsla(  0,   0%,  50%, 1.00))) bd(hsla( 30,  30%, 20%, 1.00) 4px)
