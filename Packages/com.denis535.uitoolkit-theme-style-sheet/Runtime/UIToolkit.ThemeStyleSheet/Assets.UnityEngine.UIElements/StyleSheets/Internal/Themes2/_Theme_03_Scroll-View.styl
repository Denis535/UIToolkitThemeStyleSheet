@import "../_Utils"

left-arrow  = '../../Images/Arrow_Left.png'
right-arrow = '../../Images/Arrow_Right.png'
up-arrow    = '../../Images/Arrow_Up.png'
down-arrow  = '../../Images/Arrow_Down.png'

// scroll-view-tracker
theme--scroll-view-tracker--normal                   = null                        bg(hsla( 30,  2%, 17%, 1.00) img(null, null)                              ) bd(hsla( 30,  30%, 30%, 1.00) 4px)
theme--scroll-view-tracker--hover                    = null                        bg(hsla( 30,  2%, 17%, 1.00) img(null, null)                              ) bd(hsla( 30,  30%, 30%, 1.00) 4px)
theme--scroll-view-tracker--active                   = null                        bg(hsla( 30,  2%, 17%, 1.00) img(null, null)                              ) bd(hsla( 30,  30%, 30%, 1.00) 4px)

// scroll-view-dragger
theme--scroll-view-dragger--normal                   = null                        bg(hsla( 30,  2%, 23%, 1.00) img(null, null)                              ) bd(hsla( 30,  30%, 30%, 1.00) 4px)
theme--scroll-view-dragger--hover                    = null                        bg(hsla( 30,  2%, 25%, 1.00) img(null, null)                              ) bd(hsla( 30,  30%, 50%, 1.00) 4px)
theme--scroll-view-dragger--active                   = null                        bg(hsla( 30,  2%, 22%, 1.00) img(null, null)                              ) bd(hsla( 30,  30%, 20%, 1.00) 4px)
// scroll-view-dragger
theme--scroll-view-dragger--focus                    = null                        bg(hsla( 30,  2%, 23%, 1.00) img(null, null)                              ) bd(hsla(210,  80%, 40%, 1.00) 4px)
theme--scroll-view-dragger--focus--hover             = null                        bg(hsla( 30,  2%, 25%, 1.00) img(null, null)                              ) bd(hsla(210,  80%, 50%, 1.00) 4px)
theme--scroll-view-dragger--focus--active            = null                        bg(hsla( 30,  2%, 22%, 1.00) img(null, null)                              ) bd(hsla(210,  80%, 20%, 1.00) 4px)

// scroll-view-left-arrow-button
