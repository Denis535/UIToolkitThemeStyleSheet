@import "../_Utils"

// scroll-view-tracker
theme--scroll-view-tracker--normal                   = null                        bg(hsla( 30,  1%, 17%, 1.00) img(null, null)                              ) bd(hsla( 30,  20%, 30%, 1.00) 4px)
