@import "../Internal/_Theme"

// selector
selector--scroll-view---------------------normal = // string: .unity-scroll-view
selector--scroll-view---------------------hover  = // string: .unity-scroll-view:hover
selector--light2-scroll-view--------------normal = // string: .unity-scroll-view.light2
selector--light2-scroll-view--------------hover  = // string: .unity-scroll-view.light2:hover
selector--light-scroll-view---------------normal = // string: .unity-scroll-view.light
selector--light-scroll-view---------------hover  = // string: .unity-scroll-view.light:hover
selector--gray-scroll-view----------------normal = // string: .unity-scroll-view.gray
selector--gray-scroll-view----------------hover  = // string: .unity-scroll-view.gray:hover
selector--dark-scroll-view----------------normal = // string: .unity-scroll-view.dark
selector--dark-scroll-view----------------hover  = // string: .unity-scroll-view.dark:hover
selector--dark2-scroll-view---------------normal = // string: .unity-scroll-view.dark2
selector--dark2-scroll-view---------------hover  = // string: .unity-scroll-view.dark2:hover
selector--viewport-and-vertical-scroller--normal = // string: .unity-scroll-view              #unity-content-and-vertical-scroll-container
selector--viewport------------------------normal = // string: .unity-scroll-view              #unity-content-viewport
selector--small-viewport------------------normal = // string: .unity-scroll-view.small        #unity-content-viewport
selector--medium-viewport-----------------normal = // string: .unity-scroll-view.medium       #unity-content-viewport
selector--large-viewport------------------normal = // string: .unity-scroll-view.large        #unity-content-viewport
selector--reverse-viewport----------------normal = // string: .unity-scroll-view.reverse      #unity-content-viewport
selector--content-------------------------normal = // string: .unity-scroll-view              #unity-content-container

// view
.selector--scroll-view---------------------normal // styles: add-theme(scope---------normal)
.selector--scroll-view---------------------hover  // styles: add-theme(scope---------hover )
.selector--light2-scroll-view--------------normal // styles: add-theme(light2-scope--normal)
.selector--light2-scroll-view--------------hover  // styles: add-theme(light2-scope--hover )
.selector--light-scroll-view---------------normal // styles: add-theme(light-scope---normal)
.selector--light-scroll-view---------------hover  // styles: add-theme(light-scope---hover )
.selector--gray-scroll-view----------------normal // styles: add-theme(gray-scope----normal)
.selector--gray-scroll-view----------------hover  // styles: add-theme(gray-scope----hover )
.selector--dark-scroll-view----------------normal // styles: add-theme(dark-scope----normal)
.selector--dark-scroll-view----------------hover  // styles: add-theme(dark-scope----hover )
.selector--dark2-scroll-view---------------normal // styles: add-theme(dark2-scope---normal)
.selector--dark2-scroll-view---------------hover  // styles: add-theme(dark2-scope---hover )
.selector--viewport-and-vertical-scroller--normal // styles: add-theme(null                ) 
.selector--viewport------------------------normal // styles: add-theme(null                ).add-property(overflow, hidden)
.selector--content-------------------------normal // styles: add-theme(null                )

// layout
.selector--scroll-view---------------------normal // styles: add-layout(null, auto, auto, (4px                ), (1px), (0px))
.selector--viewport-and-vertical-scroller--normal // styles: add-layout(null, auto, auto, (0px                ), (0px), (0px))
.selector--viewport------------------------normal // styles: add-layout(null, auto, auto, (0px                ), (0px), (0px))
.selector--small-viewport------------------normal // styles: add-layout(null, auto, auto, (6px  6px  5px  5px ), (0px), (0px))
.selector--medium-viewport-----------------normal // styles: add-layout(null, auto, auto, (12px 12px 10px 10px), (0px), (0px))
.selector--large-viewport------------------normal // styles: add-layout(null, auto, auto, (24px 24px 20px 20px), (0px), (0px))
.selector--content-------------------------normal // styles: add-layout(null, auto, auto, (0px                ), (0px), (0px))

// flex
.selector--scroll-view---------------------normal // styles: add-flex(0, 1, auto, auto).add-flex2(column,         flex-start, stretch)
.selector--viewport-and-vertical-scroller--normal // styles: add-flex(1, 1, auto, auto).add-flex2(row,            flex-start, stretch)
.selector--viewport------------------------normal // styles: add-flex(1, 1, auto, auto).add-flex2(column,         flex-start, stretch)
.selector--reverse-viewport----------------normal // styles: add-flex(1, 1, auto, auto).add-flex2(column-reverse, flex-start, stretch)
.selector--content-------------------------normal // styles: add-flex(1, 1, auto, auto).add-flex2(column,         flex-start, stretch)
