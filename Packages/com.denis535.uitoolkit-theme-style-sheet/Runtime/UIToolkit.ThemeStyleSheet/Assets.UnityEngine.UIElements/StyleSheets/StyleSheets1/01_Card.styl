@import "../Internal/_Theme"

// selector
selector--card--------------------normal = //@ .card
selector--card--------------------hover  = //@ .card:hover
selector--header------------------normal = //@ .card                      .header
selector--header------------------hover  = //@ .card:hover                .header
selector--content-----------------normal = //@ .card                      .content
selector--content-----------------hover  = //@ .card:hover                .content
selector--footer------------------normal = //@ .card                      .footer
selector--footer------------------hover  = //@ .card:hover                .footer
// selector
selector--dialog-card-------------normal = //@ .dialog-card
