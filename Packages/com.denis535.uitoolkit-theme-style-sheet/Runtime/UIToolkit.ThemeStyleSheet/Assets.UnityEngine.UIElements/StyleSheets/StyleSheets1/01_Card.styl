selector--info-dialog-content-----normal = //@ .info-dialog-card          .content
selector--info-dialog-content-----hover  = //@ .info-dialog-card:hover    .content
selector--info-dialog-footer------normal = //@ .info-dialog-card          .footer
selector--info-dialog-footer------hover  = //@ .info-dialog-card:hover    .footer
// selector
selector--warning-dialog-card-----normal = //@ .warning-dialog-card
selector--warning-dialog-card-----hover  = //@ .warning-dialog-card:hover
selector--warning-dialog-header---normal = //@ .warning-dialog-card       .header
selector--warning-dialog-header---hover  = //@ .warning-dialog-card:hover .header
selector--warning-dialog-content--normal = //@ .warning-dialog-card       .content
selector--warning-dialog-content--hover  = //@ .warning-dialog-card:hover .content
selector--warning-dialog-footer---normal = //@ .warning-dialog-card       .footer
selector--warning-dialog-footer---hover  = //@ .warning-dialog-card:hover .footer
// selector
selector--error-dialog-card-------normal = //@ .error-dialog-card
