// flex
.selector--card--------------------normal
    add-flex(1, 1, auto, auto)
    add-flex2(column, flex-start,   stretch)
.selector--header------------------normal
    add-flex(0, 0, auto, auto)
    add-flex2(row,    center,       center )
.selector--content-----------------normal
    add-flex(1, 1, auto, auto)
    add-flex2(column, flex-start,   stretch)
.selector--footer------------------normal
    add-flex(0, 0, auto, auto)
    add-flex2(row,    space-around, center )
