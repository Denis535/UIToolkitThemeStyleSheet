selector--dialog-header-----------hover  = '.dialog-card:hover .header'
selector--dialog-content----------normal = '.dialog-card       .content'
selector--dialog-content----------hover  = '.dialog-card:hover .content'
selector--dialog-footer-----------normal = '.dialog-card       .footer'
selector--dialog-footer-----------hover  = '.dialog-card:hover .footer'
// selector
