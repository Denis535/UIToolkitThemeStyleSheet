// layout
+card--normal
    add-layout(null, auto, auto, (0px), (1px 1px 1px 1px), (0px  0px  0px  0px ))
+header--normal
    add-layout(null, auto, auto, (0px), (0px 0px 0px 1px), (24px 24px 20px 20px))
+content--normal
    add-layout(null, auto, auto, (0px), (0px 0px 0px 0px), (24px 24px 20px 20px))
+footer--normal
    add-layout(null, auto, auto, (0px), (0px 0px 1px 0px), (24px 24px 20px 20px))
+footer--normal
    *
        add-layout(width: 25%)
// layout
+dialog-card--normal
