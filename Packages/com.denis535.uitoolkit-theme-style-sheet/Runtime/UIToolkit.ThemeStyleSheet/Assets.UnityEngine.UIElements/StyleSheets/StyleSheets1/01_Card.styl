selector--error-dialog-footer-----normal = //@ .error-dialog-card         .footer
selector--error-dialog-footer-----hover  = //@ .error-dialog-card:hover   .footer

// view
.selector--card--------------------normal
    add-theme(card--------------------normal)
    add-font(null, null, null)
.selector--card--------------------hover
    add-theme(card--------------------hover )
.selector--header------------------normal
    add-theme(header------------------normal)
    add-font(null, 130%, bold)
.selector--header------------------hover
    add-theme(header------------------hover )
.selector--content-----------------normal
    add-theme(content-----------------normal)
    add-font(null, null, null)
.selector--content-----------------hover
    add-theme(content-----------------hover )
.selector--footer------------------normal
    add-theme(footer------------------normal)
    add-font(null, 120%, bold)
.selector--footer------------------hover
    add-theme(footer------------------hover )
// view
.selector--dialog-card-------------normal
