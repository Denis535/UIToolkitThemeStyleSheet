@import "../Internal/_Theme"

// selector
selector--scope---------normal = // string: .scope
selector--small-scope---normal = // string: .scope.small
selector--medium-scope--normal = // string: .scope.medium
selector--large-scope---normal = // string: .scope.large
selector--column-scope--normal = // string: .column-scope
selector--row-scope-----normal = // string: .row-scope

// view
add-style(scope---------normal) theme()
flush()

// layout
add-style(scope---------normal) layout(null, auto, auto, (0px), (0px), (0px                ))
add-style(small-scope---normal) layout(null, auto, auto, (0px), (0px), (6px  6px  5px  5px ))
add-style(medium-scope--normal) layout(null, auto, auto, (0px), (0px), (12px 12px 10px 10px))
add-style(large-scope---normal) layout(null, auto, auto, (0px), (0px), (24px 24px 20px 20px))
flush()

// flex
add-style(column-scope--normal) flex(0, 1, auto, auto) flex2(column, flex-start, stretch)
add-style(row-scope-----normal) flex(0, 1, auto, auto) flex2(row,    flex-start, stretch)
flush()
