@import "../Internal/_Theme"

// selector
selector--scope---------normal = // string: .scope
selector--small-scope---normal = // string: .scope.small
selector--medium-scope--normal = // string: .scope.medium
selector--large-scope---normal = // string: .scope.large
selector--column-scope--normal = // string: .column-scope
selector--row-scope-----normal = // string: .row-scope

// view
.selector--scope---------normal // styles: add-theme(null)

// layout
.selector--scope---------normal // styles: add-layout(null, auto, auto, (0px), (0px), (0px                ))
.selector--small-scope---normal // styles: add-layout(null, auto, auto, (0px), (0px), (6px  6px  5px  5px ))
.selector--medium-scope--normal // styles: add-layout(null, auto, auto, (0px), (0px), (12px 12px 10px 10px))
.selector--large-scope---normal // styles: add-layout(null, auto, auto, (0px), (0px), (24px 24px 20px 20px))

// flex
.selector--column-scope--normal // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, stretch)
.selector--row-scope-----normal // styles: add-flex(0, 1, auto, auto).add-flex2(row,    flex-start, stretch)
