@import "../Internal/_Theme"

// selector
selector--group---------normal = // string: .group
selector--group---------hover  = // string: .group:hover
selector--light2-group--normal = // string: .group.light2
selector--light2-group--hover  = // string: .group.light2:hover
selector--light-group---normal = // string: .group.light
selector--light-group---hover  = // string: .group.light:hover
selector--gray-group----normal = // string: .group.gray
selector--gray-group----hover  = // string: .group.gray:hover
selector--dark-group----normal = // string: .group.dark
selector--dark-group----hover  = // string: .group.dark:hover
selector--dark2-group---normal = // string: .group.dark2
selector--dark2-group---hover  = // string: .group.dark2:hover
selector--small-group---normal = // string: .group.small
selector--medium-group--normal = // string: .group.medium
selector--large-group---normal = // string: .group.large
selector--column-group--normal = // string: .column-group
selector--row-group-----normal = // string: .row-group

// view
add-style(group---------normal) theme(scope---------normal)
add-style(group---------hover ) theme(scope---------hover )
add-style(light2-group--normal) theme(light2-scope--normal)
add-style(light2-group--hover ) theme(light2-scope--hover )
add-style(light-group---normal) theme(light-scope---normal)
add-style(light-group---hover ) theme(light-scope---hover )
add-style(gray-group----normal) theme(gray-scope----normal)
add-style(gray-group----hover ) theme(gray-scope----hover )
add-style(dark-group----normal) theme(dark-scope----normal)
add-style(dark-group----hover ) theme(dark-scope----hover )
add-style(dark2-group---normal) theme(dark2-scope---normal)
add-style(dark2-group---hover ) theme(dark2-scope---hover )
flush()

// layout
add-style(group---------normal) layout(null, auto, auto, (4px), (1px), (0px                ))
add-style(small-group---normal) layout(null, auto, auto, (4px), (1px), (6px  6px  5px  5px ))
add-style(medium-group--normal) layout(null, auto, auto, (4px), (1px), (12px 12px 10px 10px))
add-style(large-group---normal) layout(null, auto, auto, (4px), (1px), (24px 24px 20px 20px))
flush()

// flex
add-style(column-group--normal) flex(0, 1, auto, auto) flex2(column, flex-start, stretch)
add-style(row-group-----normal) flex(0, 1, auto, auto) flex2(row,    flex-start, stretch)
flush()
