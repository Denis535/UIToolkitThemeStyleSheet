@import "../Internal/_Theme"

// selector
selector--group---------normal = // string: .group
selector--group---------hover  = // string: .group:hover
selector--light2-group--normal = // string: .group.light2
selector--light2-group--hover  = // string: .group.light2:hover
selector--light-group---normal = // string: .group.light
selector--light-group---hover  = // string: .group.light:hover
selector--gray-group----normal = // string: .group.gray
selector--gray-group----hover  = // string: .group.gray:hover
selector--dark-group----normal = // string: .group.dark
selector--dark-group----hover  = // string: .group.dark:hover
selector--dark2-group---normal = // string: .group.dark2
selector--dark2-group---hover  = // string: .group.dark2:hover
selector--small-group---normal = // string: .group.small
selector--medium-group--normal = // string: .group.medium
selector--large-group---normal = // string: .group.large
selector--column-group--normal = // string: .column-group
selector--row-group-----normal = // string: .row-group

// view
.selector--group---------normal // styles: add-theme(scope---------normal)
.selector--group---------hover  // styles: add-theme(scope---------hover )
.selector--light2-group--normal // styles: add-theme(light2-scope--normal)
.selector--light2-group--hover  // styles: add-theme(light2-scope--hover )
.selector--light-group---normal // styles: add-theme(light-scope---normal)
.selector--light-group---hover  // styles: add-theme(light-scope---hover )
.selector--gray-group----normal // styles: add-theme(gray-scope----normal)
.selector--gray-group----hover  // styles: add-theme(gray-scope----hover )
.selector--dark-group----normal // styles: add-theme(dark-scope----normal)
.selector--dark-group----hover  // styles: add-theme(dark-scope----hover )
.selector--dark2-group---normal // styles: add-theme(dark2-scope---normal)
.selector--dark2-group---hover  // styles: add-theme(dark2-scope---hover )

// layout
.selector--group---------normal // styles: add-layout(null, auto, auto, (4px), (1px), (0px                ))
.selector--small-group---normal // styles: add-layout(null, auto, auto, (4px), (1px), (6px  6px  5px  5px ))
.selector--medium-group--normal // styles: add-layout(null, auto, auto, (4px), (1px), (12px 12px 10px 10px))
.selector--large-group---normal // styles: add-layout(null, auto, auto, (4px), (1px), (24px 24px 20px 20px))

// flex
.selector--column-group--normal // styles: add-flex(0, 1, auto, auto).add-flex2(column, flex-start, null, stretch)
.selector--row-group-----normal // styles: add-flex(0, 1, auto, auto).add-flex2(row,    flex-start, null, stretch)
