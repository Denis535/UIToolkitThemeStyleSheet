@import "../Internal/_Theme"

// selector
selector--field       = // string: .unity-base-field:*
selector--field-label = // string: .unity-base-field:* .unity-base-field__label
selector--field-input = // string: .unity-base-field:* .unity-base-field__input

// view
.selector--field                            // styles: add-theme(field--------normal                )
.selector--field:hover                      // styles: add-theme(field--------hover                 )
.selector--field:active                     // styles: add-theme(field--------active                )
.selector--field:focus                      // styles: add-theme(field--------focus                 )
.selector--field:focus:hover                // styles: add-theme(field--------focus--hover          )
.selector--field:focus:active               // styles: add-theme(field--------focus--active         )
.selector--field.invalid                    // styles: add-theme(field--------invalid               )
.selector--field.invalid:hover              // styles: add-theme(field--------invalid--hover        )
.selector--field.invalid:active             // styles: add-theme(field--------invalid--active       )
.selector--field.invalid:focus              // styles: add-theme(field--------invalid--focus        )
.selector--field.invalid:focus:hover        // styles: add-theme(field--------invalid--focus--hover )
.selector--field.invalid:focus:active       // styles: add-theme(field--------invalid--focus--active)
// view
.selector--field-label                      // styles: add-theme(field-label--normal                ).add-font(null, null, null).add-text(middle-left, null, null)
.selector--field-label:hover                // styles: add-theme(field-label--hover                 )
.selector--field-label:active               // styles: add-theme(field-label--active                )
.selector--field-label:focus                // styles: add-theme(field-label--focus                 )
.selector--field-label:focus:hover          // styles: add-theme(field-label--focus--hover          )
.selector--field-label:focus:active         // styles: add-theme(field-label--focus--active         )
.selector--field-label.invalid              // styles: add-theme(field-label--invalid               )
.selector--field-label.invalid:hover        // styles: add-theme(field-label--invalid--hover        )
.selector--field-label.invalid:active       // styles: add-theme(field-label--invalid--active       )
.selector--field-label.invalid:focus        // styles: add-theme(field-label--invalid--focus        )
.selector--field-label.invalid:focus:hover  // styles: add-theme(field-label--invalid--focus--hover )
.selector--field-label.invalid:focus:active // styles: add-theme(field-label--invalid--focus--active)
// view
.selector--field-input                      // styles: add-theme(field-input--normal                ).add-font(null, null, null).add-text(middle-left, null, null)
.selector--field-input:hover                // styles: add-theme(field-input--hover                 )
.selector--field-input:active               // styles: add-theme(field-input--active                )
.selector--field-input:focus                // styles: add-theme(field-input--focus                 )
.selector--field-input:focus:hover          // styles: add-theme(field-input--focus--hover          )
.selector--field-input:focus:active         // styles: add-theme(field-input--focus--active         )
.selector--field-input.invalid              // styles: add-theme(field-input--invalid               )
.selector--field-input.invalid:hover        // styles: add-theme(field-input--invalid--hover        )
.selector--field-input.invalid:active       // styles: add-theme(field-input--invalid--active       )
.selector--field-input.invalid:focus        // styles: add-theme(field-input--invalid--focus        )
.selector--field-input.invalid:focus:hover  // styles: add-theme(field-input--invalid--focus--hover )
.selector--field-input.invalid:focus:active // styles: add-theme(field-input--invalid--focus--active)

// layout
.selector--field       // styles: add-layout(null, auto, auto, (4px            ), (0px), (0px                ))
.selector--field-label // styles: add-layout(null, auto, auto, (0px 4px 0px 0px), (1px), (12px 12px 10px 10px))
.selector--field-input // styles: add-layout(null, auto, auto, (0px            ), (1px), (12px 12px 10px 10px))

// flex
.selector--field       // styles: add-flex(0, 1, auto, auto).add-flex2(row, flex-start, null, stretch)
.selector--field-label // styles: add-flex(0, 1, auto, auto)
.selector--field-input // styles: add-flex(1, 1, auto, auto).add-flex2(row, flex-end,   null, stretch)
